# Frontend Environment Variables
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Fitness AI
VITE_APP_VERSION=1.0.0

# Backend Environment Variables
DATABASE_URL=mongodb://admin:admin123@localhost:27017/fitness_app?authSource=admin
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# AI Model Configuration
AI_MODEL_PATH=/app/ai/models
RECOMMENDATION_THRESHOLD=0.7

# Admin Configuration
ADMIN_EMAIL=admin@fitnesshq.com
ADMIN_PASSWORD=admin-secure-password

# API Configuration
API_VERSION=v1
API_TITLE=Fitness AI API
DEBUG=False

# Logging
LOG_LEVEL=INFO

# File Upload
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif

# MongoDB Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123
MONGO_INITDB_DATABASE=fitness_app

# Redis (for caching, optional)
REDIS_URL=redis://redis:6379

# External APIs
OPENWEATHER_API_KEY=optional

# Timezone
TIMEZONE=UTC

# Production Settings
ENVIRONMENT=development
